{
  "schemaVersion": 1,
  "document": {
    "id": "demo-poster",
    "name": "Demo Poster",
    "width": 960,
    "height": 640,
    "unit": "px",
    "unitSystem": {
      "unit": "px",
      "label": "px",
      "unitsPerInch": 96,
      "pixelsPerUnit": 1,
      "precision": 0
    }
  },
  "referenceGrid": {
    "columns": 6,
    "rows": 4,
    "columnLabels": ["A", "B", "C", "D", "E", "F"],
    "rowLabels": ["1", "2", "3", "4"]
  },
  "layers": [
    {
      "id": "background",
      "asset": "layers/background.toml",
      "objectIds": ["poster-bg"]
    },
    {
      "id": "product",
      "asset": "layers/product.toml",
      "objectIds": [
        "product-base-shadow",
        "generated-product-image",
        "generated-product-sketch",
        "generated-product-alpha",
        "product-silhouette-body",
        "product-highlight"
      ]
    },
    {
      "id": "foreground",
      "asset": "layers/foreground.toml",
      "objectIds": [
        "logo",
        "headline",
        "price-chip",
        "cta-bg",
        "cta-label",
        "feature-chip-1",
        "feature-chip-2",
        "feature-chip-3"
      ]
    }
  ],
  "objects": {
    "poster-bg": {
      "kind": "rect",
      "asset": "objects/poster-bg.toml"
    },
    "product-base-shadow": {
      "kind": "ellipse",
      "asset": "objects/product-base-shadow.toml"
    },
    "generated-product-image": {
      "kind": "image",
      "asset": "objects/generated-product-image.toml"
    },
    "generated-product-alpha": {
      "kind": "image",
      "asset": "objects/generated-product-alpha.toml"
    },
    "generated-product-sketch": {
      "kind": "sketchOverlay",
      "asset": "objects/generated-product-sketch.sketch.toml"
    },
    "product-silhouette-body": {
      "kind": "rect",
      "asset": "objects/product-silhouette-body.toml"
    },
    "product-highlight": {
      "kind": "ellipse",
      "asset": "objects/product-highlight.toml"
    },
    "logo": {
      "kind": "text",
      "asset": "objects/logo.toml"
    },
    "headline": {
      "kind": "text",
      "asset": "objects/headline.toml"
    },
    "price-chip": {
      "kind": "rect",
      "asset": "objects/price-chip.toml"
    },
    "cta-bg": {
      "kind": "rect",
      "asset": "objects/cta-bg.toml"
    },
    "cta-label": {
      "kind": "text",
      "asset": "objects/cta-label.toml"
    },
    "feature-chip-1": {
      "kind": "rect",
      "asset": "objects/feature-chip-1.toml"
    },
    "feature-chip-2": {
      "kind": "rect",
      "asset": "objects/feature-chip-2.toml"
    },
    "feature-chip-3": {
      "kind": "rect",
      "asset": "objects/feature-chip-3.toml"
    }
  },
  "relations": [
    {
      "kind": "alphaMapFor",
      "sourceId": "generated-product-image",
      "alphaId": "generated-product-alpha"
    },
    {
      "kind": "sketchOverlayFor",
      "sourceId": "generated-product-image",
      "overlayId": "generated-product-sketch"
    }
  ]
}
